# =============================================================================
# Caerphilly RFC Tracker — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Find these in your Supabase project dashboard:
# Settings > API > Project URL and Project API keys

# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose to the browser. Only bypasses RLS for
# public tables. Your tables use RLS so authenticated access is still required.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose this to the browser.
# Only used server-side for admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
